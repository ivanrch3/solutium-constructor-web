VITE_APP_MADRE_API_URL=https://app.solutium.app/
VITE_API_BASE_URL=http://localhost:3000/api
VITE_CONSTRUCTOR_PUBLIC_BASE_URL=http://localhost:3010/

# Crear con IA / AIPagePlan broker
# true usa el broker seguro de App Madre y consume créditos IA reales.
# false usa fallback/mock local editable para desarrollo sin consumo.
VITE_ENABLE_AI_PAGE_PLAN_BROKER=false
VITE_AI_PAGE_PLAN_BROKER_URL=https://app.solutium.app/api/ai/page-plan/generate
VITE_REFERENCE_URL_ANALYSIS_BROKER_URL=https://app.solutium.app/api/ai/reference-url/analyze
VITE_ENABLE_REFERENCE_URL_PAGE_PLAN_BROKER=false
VITE_REFERENCE_URL_PAGE_PLAN_BROKER_URL=https://app.solutium.app/api/ai/reference-url/generate-page-plan

VITE_ENABLE_REFERENCE_URL_VISUAL_SCAN=true
VITE_REFERENCE_URL_VISUAL_SCAN_URL=https://app.solutium.app/api/ai/reference-url/visual-scan
